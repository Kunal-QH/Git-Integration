<section class="notebook-section">
  <div class="page-width">
    <div class="notebook-header">
      <h2 class="notebook-title">{{ section.settings.heading }}</h2>
      <p class="notebook-subtitle">{{ section.settings.subheading }}</p>
    </div>

    <div class="notebook-grid">
      {% for block in section.blocks %}
        <article class="notebook-card">
          <a class="notebook-img-a" href="{{ block.settings.link }}">
            <div class="notebook-image">
              {{ block.settings.image | image_url: width: 600 | image_tag }}
            </div>
          </a>

          <div class="notebook-content">
            <div class="notebook-tags">
              <span class="tag">{{ block.settings.tag }}</span>
            </div>

            <h3>{{ block.settings.title }}</h3>

            <p>{{ block.settings.text }}</p>

            <a class="read-more" href="{{ block.settings.link }}"> Read More </a>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .notebook-section {
    padding: 80px 60px;
    background: #f6f2e9;
  }

  .notebook-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .notebook-title {
    font-size: 42px;
    font-weight: 800;
    color: #243f35;
    margin-bottom: 10px;
  }

  .notebook-subtitle {
    letter-spacing: 1px;
    font-size: 14px;
    color: #4a5d52;
    margin-bottom: 30px;
  }

  .notebook-header h2 {
    font-size: 40px;
    font-weight: 700;
  }

  .notebook-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .notebook-card {
    max-height: 20vh;
    min-width: 30vw;
    background: white;
    border-radius: 22px;
    overflow: hidden;
    border: 1px solid #d9e0c7;
    display: flex;
    flex-direction: column;
  }

  .notebook-card > .notebook-img-a {
    height: 100%;
  }

  .notebook-image img {
    object-fit: contain;
    {% comment %} height: 100%; {% endcomment %}
    {% comment %} width: 100%; {% endcomment %}
  }

  .notebook-content {
    padding: 22px;
  }

  .tag {
    background: #e1f2ef;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 12px;
  }

  .read-more {
    font-weight: 600;
    margin-top: 10px;
    display: inline-block;
    color: #001500;
  }
</style>

{% schema %}
{
  "name": "Notebook Blog",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Notebook"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Last minute notes on all things kids"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "tag", "label": "Tag" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "text", "label": "Description" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "Notebook Blog" }]
}
{% endschema %}
