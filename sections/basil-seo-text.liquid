<section class="seo-text">
  <div class="page-width">
    <h2>{{ section.settings.heading }}</h2>

    <div class="seo-content">
      <p class="short">{{ section.settings.short_text }}</p>

      <div class="full">
        {{ section.settings.full_text }}
        <button class="read-less-btn">Read less</button>
      </div>

      <button class="read-more-btn">Read more</button>
    </div>
  </div>
</section>

<style>
  .seo-text {
    padding: 60px 30px;
    background: #f5f1e8;
  }

  .seo-text h2 {
    font-size: 36px;
    margin-bottom: 16px;
  }

  .seo-content {
    max-width: 900px;
  }

  .full {
    display: none;
    margin-top: 10px;
  }

  .read-more-btn,
  .read-less-btn {
    margin-top: 10px;
    background: none;
    border: none;
    font-weight: 700;
    color: #010;
    font-size: 1.2em;
    cursor: pointer;
    text-decoration: underline;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const moreBtn = document.querySelector('.read-more-btn');
    if (moreBtn) {
      moreBtn.addEventListener('click', () => {
        document.querySelector('.full').style.display = 'block';
        moreBtn.style.display = 'none';
      });
    }

    const lessBtn = document.querySelector('.read-less-btn');
    if (lessBtn) {
      lessBtn.addEventListener('click', () => {
        document.querySelector('.full').style.display = 'none';
        moreBtn.style.display = 'initial';
      });
    }
  });
</script>

{% schema %}
{
  "name": "SEO Text",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "short_text",
      "label": "Short Text"
    },
    {
      "type": "richtext",
      "id": "full_text",
      "label": "Full Text"
    }
  ],
  "presets": [{ "name": "SEO Text" }]
}
{% endschema %}
