<section class="founder-section">
  <div class="page-width">
    <div class="founder-grid">
      <div class="founder-video">
        {% if section.settings.video != blank %}
          {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: true }}
        {% endif %}
      </div>

      <div class="founder-content">
        <svg class="quote" xmlns="http://www.w3.org/2000/svg" width="46" height="41" viewBox="0 0 46 41" fill="none">
          <path d="M42.3077 0.708496L45.8462 9.85578C43.0769 10.1659 40.8718 10.7343 39.2308 11.5612C37.6923 12.3881 36.9231 14.0935 36.9231 16.6775V18.693H46V40.7085H26.3077V18.3829C26.3077 13.215 27.4872 9.13227 29.8462 6.13486C32.3077 3.13744 36.4615 1.32866 42.3077 0.708496ZM16 0.708496L19.5385 9.85578C16.7692 10.1659 14.5641 10.7343 12.9231 11.5612C11.3846 12.3881 10.6154 14.0935 10.6154 16.6775V18.693H19.6923V40.7085H0V18.3829C0 13.215 1.17949 9.13227 3.53846 6.13486C6 3.13744 10.1538 1.32866 16 0.708496Z" fill="#F9F9EC"></path>
        </svg>

        <h2>{{ section.settings.heading }}</h2>

        <hr>

        <p class="founder-name">
          {{ section.settings.name }}
        </p>

        <p>{{ section.settings.text }}</p>

        <button class="founder-btn" href="{{ section.settings.button_link }}">
          {{ section.settings.button_label }}
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .founder-section {
    position: relative;
    background: #c8a1cc;
    padding: 100px 40px;
    margin: 130px 0 50px 0;
  }

  .founder-section::before {
    content: '';
    position: absolute;
    top: -8.5em;
    left: 0;
    width: 100%;
    height: 13em;
    background-image: url('https://cdn.shopify.com/s/files/1/0782/5388/3681/files/Desktop_181ec3b1-81be-4642-bee5-ee73f163164d.svg');
    background-size: cover;
  }

  .founder-section:after {
    content: '';
    position: absolute;
    bottom: -8em;
    left: 0;
    width: 100%;
    height: 13em;
    background-image: url('https://cdn.shopify.com/s/files/1/0782/5388/3681/files/Desktop_eb846e38-a17d-43ce-ad49-b63da45be60a.svg');
    background-size: cover;
  }

  .founder-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .founder-video video {
    border-radius: 24px;
    width: 100%;
    height: auto;
  }

  .founder-content h2 {
    font-size: 48px;
    margin: 10px 0;
  }

  .founder-name {
    font-weight: 700;
  }

  .quote {
    padding-bottom: 2em;
  }

  hr {
    margin: 2em 0;
  }

  .founder-btn {
    border: none;
    display: inline-block;
    margin-top: 20px;
    background: white;
    padding: 12px 24px;
    border-radius: 30px;
    font-weight: 600;
  }
</style>

{% schema %}
{
  "name": "Founder Quote",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Founder Video"
    },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "name", "label": "Name" },
    { "type": "textarea", "id": "text", "label": "Description" },
    { "type": "text", "id": "button_label", "label": "Button Label" },
    { "type": "url", "id": "button_link", "label": "Button Link" }
  ],
  "presets": [{ "name": "Founder Quote" }]
}
{% endschema %}
