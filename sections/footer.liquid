<footer class="basil-footer">
  <div class="page-width footer-grid">
    <div class="footer-brand">
      <h2>{{ shop.name }}</h2>

      <p>{{ section.settings.brand_text }}</p>

      <div class="marketplaces">
        {% assign marketplace_blocks = section.blocks | where: 'type', 'marketplace' %}
        {% assign social_blocks = section.blocks | where: 'type', 'social' %}
        <h4 style="border-top: 1px dashed #f6c85f; padding-top: 1em;">Now Available At:</h4>
        {% for block in marketplace_blocks %}
          <img src="{{ block.settings.logo | image_url: width: 50 }}">
        {% endfor %}

        <h4 style="border-top: 1px dashed #f6c85f; padding-top: 1em;">Find us Here!</h4>
        {% for block in social_blocks %}
          <a href="{{ block.link }}"><img src="{{ block.settings.logo | image_url: width: 50 }}"></a>
        {% endfor %}
      </div>
    </div>

    <div class="footer-menu">
      <h4>Shop +</h4>

      <ul>
        {% for link in linklists[section.settings.shop_menu].links %}
          <li>
            <a href="{{ link.url }}">{{ link.title }}</a>
          </li>
        {% endfor %}
      </ul>
    </div>

    <div class="footer-menu">
      <h4>More</h4>

      <ul>
        {% for link in linklists[section.settings.more_menu].links %}
          <li>
            <a href="{{ link.url }}">{{ link.title }}</a>
          </li>
        {% endfor %}
      </ul>
    </div>

    <div class="footer-newsletter">
      <h4>Manufactured By</h4>
      {{ section.settings.manufactured_text }}

      <h4 style="border-top: 1px dashed #f6c85f; padding-top: 1em;">{{ section.settings.newsletter_title }}</h4>

      <p>{{ section.settings.newsletter_text }}</p>

      <form method="post" action="/contact#newsletter">
        <input type="email" name="contact[email]" placeholder="Enter your email">

        <button type="submit">→</button>
      </form>
    </div>
  </div>

  <div class="footer-bottom" style="border-top: 1px dashed #f6c85f; padding-top: 1em;">
    <p>
      © {{ 'now' | date: '%Y' }}
      {{ shop.name }}
    </p>

    <div class="footer-bottom-links">
      {% for link in linklists[section.settings.bottom_menu].links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </div>
  </div>
</footer>

<style>
  .basil-footer {
    background: #e56565;
    color: white;
    padding: 80px 40px 30px 40px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 2fr;
    gap: 40px;
  }

  .footer-menu ul {
    list-style: none;
    padding: 0;
  }

  .footer-menu li {
    margin-bottom: 10px;
  }

  .footer-menu a {
    color: white;
    text-decoration: none;
  }

  .footer-newsletter form {
    display: flex;
    margin-top: 15px;
  }

  .footer-newsletter input {
    flex: 1;
    padding: 12px;
    border-radius: 30px 0 0 30px;
    border: none;
  }

  .footer-newsletter button {
    padding: 12px 18px;
    border: none;
    background: #ffc83d;
    border-radius: 0 30px 30px 0;
  }

  .footer-bottom {
    margin-top: 40px;
    display: flex;
    justify-content: space-between;
    padding-top: 20px;
  }

  .footer-bottom-links a {
    margin-left: 20px;
    color: white;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 10px;
    }
  }
</style>

{% schema %}
{
  "name": "Basil Footer",
  "settings": [
    {
      "type": "richtext",
      "id": "brand_text",
      "label": "Brand Text"
    },
    {
      "type": "richtext",
      "id": "manufactured_text",
      "label": "Manufactured By Text"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter Title"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter Text"
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop Menu"
    },
    {
      "type": "link_list",
      "id": "more_menu",
      "label": "More Menu"
    },
    {
      "type": "link_list",
      "id": "bottom_menu",
      "label": "Bottom Menu"
    }
  ],
  "blocks": [
    {
      "type": "marketplace",
      "name": "Marketplace Logo",
      "settings": [{ "type": "image_picker", "id": "logo", "label": "Logo" }]
    },
    {
      "type": "social",
      "name": "Social Accounts",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [{ "name": "Basil Footer" }]
}
{% endschema %}
